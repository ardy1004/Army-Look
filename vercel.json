{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)\\.(css)$",
      "headers": { "Content-Type": "text/css" },
      "dest": "/assets/$1.$2"
    },
    {
      "src": "/assets/(.*)",
      "headers": { "Content-Type": "application/javascript" },
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}